{
  "sea_level": 62,
  "disable_mob_generation": false,
  "noise": {
    "min_y": -64,
    "height": 384,
    "size_horizontal": 1,
    "size_vertical": 3
  },
  "default_block": { "Name": "minecraft:stone" },
  "default_fluid": { "Name": "minecraft:water" },

  "noise_router": {
    "barrier": 0,
    "fluid_level_floodedness": 0,
    "fluid_level_spread": 0,
    "lava": 0,
    "temperature": 0,
    "vegetation": 0,

    "continents": {
      "type": "minecraft:mul",
      "argument1": {
        "type": "minecraft:noise",
        "noise": "minecraft:continentalness",
        "xz_scale": 0.8,
        "y_scale": 1.0
      },
      "argument2": 2.8
    },

    "erosion": {
      "type": "minecraft:mul",
      "argument1": {
        "type": "minecraft:noise",
        "noise": "minecraft:erosion",
        "xz_scale": 1.0,
        "y_scale": 1.0
      },
      "argument2": 0.3
    },

    "depth": 0,

    "ridges": {
      "type": "minecraft:abs",
      "argument": {
        "type": "minecraft:noise",
        "noise": "minecraft:ridges",
        "xz_scale": 1.2,
        "y_scale": 1.0
      }
    },

    "initial_density_without_jaggedness": {
      "type": "minecraft:mul",
      "argument1": "minecraft:overworld/base_3d_noise",
      "argument2": 1.5
    },

    "final_density": {
      "type": "minecraft:add",
      "argument1": {
        "type": "minecraft:mul",
        "argument1": "minecraft:overworld/base_3d_noise",
        "argument2": 2.5
      },
      "argument2": {
        "type": "minecraft:mul",
        "argument1": {
          "type": "minecraft:noise",
          "noise": "minecraft:weirdness",
          "xz_scale": 1.0,
          "y_scale": 1.0
        },
        "argument2": 2.0
      }
    },

    "vein_toggle": 0,
    "vein_ridged": 0,
    "vein_gap": 0
  },

  "surface_rule": {
    "type": "minecraft:sequence",
    "sequence": [
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:water",
          "offset": 0
        },
        "then_run": {
          "type": "minecraft:block",
          "result_state": { "Name": "minecraft:sand" }
        }
      },
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:stone_depth",
          "offset": 0,
          "surface_type": "floor"
        },
        "then_run": {
          "type": "minecraft:block",
          "result_state": { "Name": "minecraft:grass_block" }
        }
      },
      {
        "type": "minecraft:block",
        "result_state": { "Name": "minecraft:stone" }
      }
    ]
  }
}

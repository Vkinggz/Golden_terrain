{
  "sea_level": 62,
  "disable_mob_generation": false,

  "noise": {
    "min_y": -64,
    "height": 384,
    "size_horizontal": 1,
    "size_vertical": 3
  },

  "default_block": { "Name": "minecraft:stone" },
  "default_fluid": { "Name": "minecraft:water" },

  "noise_router": {
    "barrier": 0,
    "fluid_level_floodedness": 0,
    "fluid_level_spread": 0,
    "lava": 0,

    "temperature": 0,
    "vegetation": 0,

    "continents": "minecraft:continents",
    "erosion": "minecraft:erosion",
    "depth": 0,
    "ridges": "minecraft:weirdness",

    "initial_density_without_jaggedness": 1.0,
    "final_density": "minecraft:final_density",

    "vein_toggle": 0,
    "vein_ridged": 0,
    "vein_gap": 0
  },

  "surface_rule": {
    "type": "minecraft:sequence",
    "sequence": [

      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:y_above",
          "anchor": { "absolute": 60 }
        },
        "then_run": {
          "type": "minecraft:block",
          "result_state": { "Name": "minecraft:sand" }
        }
      },

      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:stone_depth",
          "offset": 0,
          "surface_type": "floor"
        },
        "then_run": {
          "type": "minecraft:block",
          "result_state": { "Name": "minecraft:grass_block" }
        }
      },

      {
        "type": "minecraft:block",
        "result_state": { "Name": "minecraft:stone" }
      }

    ]
  }
}
